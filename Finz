})

-- TOGGLE
MainTab:CreateToggle({
    Name = "Level Upp",
    CurrentValue = false,
    Callback = function(Value)
        Auto = Value
    end
})

-- HOOK REMOTE
local old
old = hookmetamethod(game,"__namecall",newcclosure(function(self,...)

    local args = {...}

    if self == remote and getnamecallmethod() == "InvokeServer" and Auto then
        
        local id = args[1]

        if id and not savedIDs[id] then
            savedIDs[id] = true

            task.spawn(function()
                while Auto do
                    remote:InvokeServer(id)
                    task.wait(0)
                end
            end)

        end

    end

    return old(self,...)
end))
