-- [ TAB: MAIN ]
local MainTab = Window:CreateTab("Main Features", 4483362458) -- Icon ID

-- Section: Automation
MainTab:CreateSection("Autofarm & Upgrades")

-- 1. Auto Rebirth
MainTab:CreateToggle({
   Name = "Auto Rebirth",
   CurrentValue = false,
   Flag = "AutoRebirth",
   Callback = function(Value)
      _G.AutoRebirth = Value
      if Value then
         task.spawn(function()
            local player = game:GetService("Players").LocalPlayer
            local knit = game:GetService("ReplicatedStorage").Packages._Index["sleitnick_knit@1.7.0"].knit
            local RF = knit.Services.RebirthService.RF
            
            local function parseNumber(str)
                str = str:gsub(",", ".")
                local num, suffix = str:match("([%d%.]+)(%a*)")
                num = tonumber(num) or 0
                local suffixes = {K=1e3,M=1e6,B=1e9,T=1e12,Qa=1e15,Qi=1e18}
                return num * (suffixes[suffix] or 1)
            end

            while _G.AutoRebirth do
                local speedText = player.PlayerGui.Windows.Rebirth:FindFirstChild("SpeedText", true)
                if speedText then
                    local text = speedText.Text
                    local current, required = text:match("Cash: (.+)/(.+)%$")
                    if current and required then
                        if parseNumber(current) >= parseNumber(required) then
                            RF.Rebirth:InvokeServer()
                        end
                    end
                end
                task.wait(0.1)
            end
         end)
      end
   end,
})

