MainTab:CreateToggle({
   Name = "Auto Rebirth",
   CurrentValue = false,
   Flag = "AutoRebirth",
   Callback = function(Value)
      _G.AutoRebirth = Value
      if Value then
          task.spawn(function()
              local player = game:GetService("Players").LocalPlayer
              local knit = game:GetService("ReplicatedStorage").Packages._Index["sleitnick_knit@1.7.0"].knit
              local RF = knit.Services.RebirthService.RF
              
              while _G.AutoRebirth do
                  local speedText = player.PlayerGui.Windows.Rebirth:FindFirstChild("SpeedText", true)
                  if speedText then
                      local text = speedText.Text
                      local current, required = text:match("Cash: (.+)/(.+)%$")
                      if current and required then
                          if parseNumber(current) >= parseNumber(required) then
                              RF.Rebirth:InvokeServer()
                          end
                      end
                  end
                  task.wait(0.1)
              end
          end)
      end
   end,
})

