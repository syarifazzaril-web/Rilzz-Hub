--- [ FUNCTIONS ] ---

local function parseNumber(str)
    str = str:gsub(",", ".")
    local num, suffix = str:match("([%d%.]+)(%a*)")
    num = tonumber(num) or 0
    local suffixes = {K=1e3,M=1e6,B=1e9,T=1e12,Qa=1e15,Qi=1e18}
    return num * (suffixes[suffix] or 1)
end

