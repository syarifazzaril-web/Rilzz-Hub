			local oh = #(options or {})*30+10
			listF.Position = UDim2.new(0, ap.X, 0, ap.Y + as.Y + 4)
			listF.Size = UDim2.new(0,145,0,0)
			listF.Visible = true
			Tween(listF,{Size=UDim2.new(0,145,0,oh)},0.28,Enum.EasingStyle.Back)
		else
			Tween(listF,{Size=UDim2.new(0,145,0,0)},0.18)
			task.delay(0.2,function() listF.Visible=false end)
		end
	end)
end

