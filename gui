local function winBtn(xOff, col, sym)
	local f = New("Frame",{
		Size=UDim2.new(0,22,0,22),Position=UDim2.new(1,xOff,0.5,-11),
		BackgroundColor3=col,BackgroundTransparency=0.7,BorderSizePixel=0,ZIndex=3,Parent=topbar
	})
	New("UICorner",{CornerRadius=UDim.new(1,0),Parent=f})
	local lbl = New("TextLabel",{
		Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text=sym,TextColor3=col,
		TextSize=11,Font=Enum.Font.GothamBold,TextTransparency=0.5,ZIndex=4,Parent=f
	})
	local btn = New("TextButton",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text="",ZIndex=5,Parent=f})
	btn.MouseEnter:Connect(function()
		Tween(f,{BackgroundTransparency=0.05},0.12)
		Tween(lbl,{TextTransparency=0},0.12)
	end)
	btn.MouseLeave:Connect(function()
		Tween(f,{BackgroundTransparency=0.7},0.12)
		Tween(lbl,{TextTransparency=0.5},0.12)
	end)
	return btn, f
end

