	New("UIGridLayout",{CellSize=UDim2.new(0,26,0,26),CellPadding=UDim2.new(0,3,0,3),
		HorizontalAlignment=Enum.HorizontalAlignment.Center,
		SortOrder=Enum.SortOrder.LayoutOrder,Parent=grd})
	New("UIPadding",{PaddingTop=UDim.new(0,5),PaddingBottom=UDim.new(0,5),
		PaddingLeft=UDim.new(0,5),PaddingRight=UDim.new(0,5),Parent=grd})

	for _,col in ipairs(colors) do
		local cb = New("TextButton",{
			Size=UDim2.new(0,28,0,28),BackgroundColor3=col,
			BorderSizePixel=0,Text="",ZIndex=202,Parent=grd
		})
		New("UICorner",{CornerRadius=UDim.new(0,7),Parent=cb})
		-- Tambah border tipis supaya warna gelap/hitam keliatan
		local brightness = col.R*0.299 + col.G*0.587 + col.B*0.114
		if brightness < 0.15 then
			New("UIStroke",{Color=Color3.fromRGB(80,80,80),Thickness=1,Parent=cb})
		end
		cb.MouseButton1Click:Connect(function()
			colorVal = col
			prev.BackgroundColor3 = col
			hexLbl.Text = string.format("#%02X%02X%02X",
				math.floor(col.R*255),math.floor(col.G*255),math.floor(col.B*255))
			Tween(palette,{Size=UDim2.new(0,262,0,0)},0.18)
			task.delay(0.2,function() palette.Visible=false end)
			if onChanged then onChanged(col) end
		end)
	end

	local paletteOpen = false
	local prevBtn = New("TextButton",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text="",ZIndex=6,Parent=prev})
	prevBtn.MouseButton1Click:Connect(function()
		-- Tutup semua palette lain dulu
		for _,v in ipairs(gui:GetDescendants()) do
			if v:IsA("Frame") and v ~= palette and v.ZIndex == 200 and v.Visible then
				v.Size = UDim2.new(0,262,0,0)
				v.Visible = false
			end
		end
		paletteOpen = not paletteOpen
		if paletteOpen then
			local ap = prev.AbsolutePosition
			local as = prev.AbsoluteSize
			local rows = math.ceil(#colors/7)
			local ph = rows * 32 + 10
			palette.Position = UDim2.new(0, ap.X - 160, 0, ap.Y + as.Y + 4)
			palette.Size = UDim2.new(0,228,0,0)
			palette.Visible = true
			Tween(palette,{Size=UDim2.new(0,262,0,ph)},0.28,Enum.EasingStyle.Back)
		else
			Tween(palette,{Size=UDim2.new(0,228,0,0)},0.18)
			task.delay(0.2,function() palette.Visible=false end)
		end
	end)
end

local function addButton(parent, title, btype, onClicked)
	local cols = {Primary=T.Surface,Default=T.Surface2,Danger=T.Danger}
	local c = C(parent, 42)
	c.BackgroundColor3 = cols[btype] or T.Surface2
	if btype=="Primary" then
		New("UIGradient",{Color=ColorSequence.new({
			ColorSequenceKeypoint.new(0,T.Accent2),ColorSequenceKeypoint.new(1,T.Accent)
		}), Rotation=90,Parent=c})
	elseif btype=="Danger" then
		New("UIGradient",{Color=ColorSequence.new({
			ColorSequenceKeypoint.new(0,Color3.fromRGB(180,30,60)),ColorSequenceKeypoint.new(1,T.Danger)
		}), Rotation=90,Parent=c})
	end
	if btype~="Default" then
		New("UIStroke",{Color=btype=="Primary" and T.Accent or T.Danger,Thickness=1,Parent=c})
	end
	New("TextLabel",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text=title,
		TextColor3=btype=="Default" and T.Text or T.White,TextSize=12,
		Font=Enum.Font.GothamBold,ZIndex=4,Parent=c})
	local btn=New("TextButton",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text="",ZIndex=5,Parent=c})
	btn.MouseEnter:Connect(function() Tween(c,{BackgroundTransparency=0.25},0.12) end)
	btn.MouseLeave:Connect(function() Tween(c,{BackgroundTransparency=0},0.12) end)
	btn.MouseButton1Click:Connect(function()
		local rip=New("Frame",{Size=UDim2.new(0,0,0,0),Position=UDim2.new(0.5,0,0.5,0),
			AnchorPoint=Vector2.new(0.5,0.5),BackgroundColor3=T.White,
			BackgroundTransparency=0.7,BorderSizePixel=0,ZIndex=8,Parent=c})
		New("UICorner",{CornerRadius=UDim.new(1,0),Parent=rip})
		Tween(rip,{Size=UDim2.new(2.5,0,2.5,0),BackgroundTransparency=1},0.42)
		task.delay(0.45,function() rip:Destroy() end)
		if onClicked then onClicked() end
	end)
	return btn
end

