	Neon     = {Bg=Color3.fromRGB(5,0,15),     Surface=Color3.fromRGB(12,5,28),    Accent=Color3.fromRGB(180,0,255),   Accent2=Color3.fromRGB(0,255,200),  Text=Color3.fromRGB(240,220,255)},
	Light    = {Bg=Color3.fromRGB(235,238,248),Surface=Color3.fromRGB(218,224,240),Accent=Color3.fromRGB(50,100,220),  Accent2=Color3.fromRGB(100,50,200), Text=Color3.fromRGB(20,30,60)},
}

local function applyTheme(name)
	local th = Themes[name] or Themes.Dark
	-- Simpan warna lama untuk compare
	local oldBg      = T.Bg
	local oldSurface = T.Surface
	local oldAccent  = T.Accent
	local oldText    = T.Text
	-- Update global
	T.Bg      = th.Bg
	T.Surface = th.Surface
	T.Accent  = th.Accent
	T.Accent2 = th.Accent2
	T.Text    = th.Text or Color3.fromRGB(220,232,252)
	-- Apply ke elemen utama
	Tween(win,     {BackgroundColor3=th.Bg},      0.3)
	Tween(topbar,  {BackgroundColor3=th.Surface},  0.3)
	Tween(sidebar, {BackgroundColor3=th.Surface},  0.3)
	Tween(gline,   {BackgroundColor3=th.Accent},   0.3)
	Tween(pillLine,{BackgroundColor3=th.Accent},   0.3)
	pillStroke.Color = th.Accent
	win:FindFirstChildOfClass("UIStroke").Color = Color3.fromRGB(
		math.floor(th.Accent.R*60), math.floor(th.Accent.G*60), math.floor(th.Accent.B*180))
	-- Apply ke semua Frame, TextLabel, UIStroke di dalam win
	for _,v in ipairs(win:GetDescendants()) do
		if v:IsA("Frame") then
			if v.BackgroundColor3 == oldBg then
				v.BackgroundColor3 = th.Bg
			elseif v.BackgroundColor3 == oldSurface then
				v.BackgroundColor3 = th.Surface
			end
		end
		if v:IsA("TextLabel") and v.TextColor3 == oldText then
			v.TextColor3 = T.Text
		end
		if v:IsA("TextLabel") and v.TextColor3 == oldAccent then
			v.TextColor3 = th.Accent
		end
		if v:IsA("UIStroke") and v.Color == oldAccent then
			v.Color = th.Accent
		end
	end
end

