			TextSize=11,Font=Enum.Font.GothamSemibold,ZIndex=201,Parent=listF})
		New("UICorner",{CornerRadius=UDim.new(0,7),Parent=ob})
		ob.MouseEnter:Connect(function() Tween(ob,{BackgroundTransparency=0.65},0.1) end)
		ob.MouseLeave:Connect(function() Tween(ob,{BackgroundTransparency=1},0.1) end)
		ob.MouseButton1Click:Connect(function()
			sel=opt; selLbl.Text=opt; open=false
			for _,ch in ipairs(listF:GetChildren()) do
				if ch:IsA("TextButton") then ch.TextColor3 = ch.Text==sel and T.Accent or T.Text end
			end
			Tween(listF,{Size=UDim2.new(0,145,0,0)},0.18)
			task.delay(0.2, function() listF.Visible=false end)
			if onChanged then onChanged(opt) end
		end)
	end

	local ob2 = New("TextButton",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text="",ZIndex=6,Parent=display})
	ob2.MouseButton1Click:Connect(function()
		open=not open
