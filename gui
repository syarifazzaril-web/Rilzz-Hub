-- ── MINIMIZE / EXPAND ─────────────────────────────────────
local minimized = false

local function doMinimize()
	minimized = true
	win.Visible = false
	-- Reset blur saat minimize
	local Lighting = game:GetService("Lighting")
	local be = Lighting:FindFirstChildOfClass("BlurEffect")
	if be then be.Size = 0 end
	pill.Position = UDim2.new(0.5,-105,0,-50)
	pill.Size   = UDim2.new(0,0,0,42)
	pill.BackgroundTransparency = 1
	pill.Visible = true
	Tween(pill, {Size=UDim2.new(0,210,0,42), BackgroundTransparency=0.25, Position=UDim2.new(0.5,-105,0,6)}, 0.32, Enum.EasingStyle.Back)
end

local function doExpand()
	minimized = false
	pill.Visible = false
	win.Size    = UDim2.new(0,580,0,0)
	win.Visible = true
	Tween(win, {Size=UDim2.new(0,580,0,415)}, 0.35, Enum.EasingStyle.Back)
end

minBtn.MouseButton1Click:Connect(function()
	if not dragMoved then
		dragMoved = false
