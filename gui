local function runLoad(i, cb)
	if i > #loadSteps then task.wait(0.15); cb(); return end
	local s = loadSteps[i]
	progLbl.Text = s.t
	Tween(progFill, {Size=UDim2.new(s.p,0,1,0)}, 0.35)
	task.delay(0.4, function() runLoad(i+1, cb) end)
end

