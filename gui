local function addSlider(parent, title, pct, color, onChanged)
	local c = C(parent, 58)
	local tr = New("Frame",{Size=UDim2.new(1,0,0,22),Position=UDim2.new(0,0,0,7),BackgroundTransparency=1,ZIndex=4,Parent=c})
	L(tr, title, T.Text, 12, Enum.Font.GothamSemibold, nil, nil, UDim2.new(0.65,0,1,0))
	local vl = New("TextLabel",{Size=UDim2.new(0.35,0,1,0),Position=UDim2.new(0.65,0,0,0),
		BackgroundTransparency=1,Text=tostring(math.floor(pct*100)),
		TextColor3=color or T.Accent,TextSize=11,Font=Enum.Font.Code,
		TextXAlignment=Enum.TextXAlignment.Right,ZIndex=4,Parent=tr})
	local track = New("Frame",{Size=UDim2.new(1,0,0,6),Position=UDim2.new(0,0,0,36),
		BackgroundColor3=T.Surface2,BorderSizePixel=0,ZIndex=4,Parent=c})
	New("UICorner",{CornerRadius=UDim.new(1,0),Parent=track})
	New("UIStroke",{Color=T.Border,Thickness=1,Parent=track})
	local fill = New("Frame",{Size=UDim2.new(pct,0,1,0),BackgroundColor3=color or T.Accent,BorderSizePixel=0,ZIndex=5,Parent=track})
	New("UICorner",{CornerRadius=UDim.new(1,0),Parent=fill})
	New("UIGradient",{Color=ColorSequence.new({
		ColorSequenceKeypoint.new(0,T.Accent2),ColorSequenceKeypoint.new(1,color or T.Accent)
	}),Parent=fill})
	local knob = New("Frame",{Size=UDim2.new(0,14,0,14),Position=UDim2.new(pct,-7,0.5,-7),
		BackgroundColor3=T.White,BorderSizePixel=0,ZIndex=6,Parent=track})
	New("UICorner",{CornerRadius=UDim.new(1,0),Parent=knob})
	New("UIStroke",{Color=color or T.Accent,Thickness=1.5,Parent=knob})
	local dragging = false
	local sb = New("TextButton",{Size=UDim2.new(1,0,0,22),Position=UDim2.new(0,0,0,-8),
		BackgroundTransparency=1,Text="",ZIndex=7,Parent=track})
	sb.MouseButton1Down:Connect(function(x)
		dragging=true
		local p=math.clamp((x-track.AbsolutePosition.X)/track.AbsoluteSize.X,0,1)
		fill.Size=UDim2.new(p,0,1,0); knob.Position=UDim2.new(p,-7,0.5,-7)
		vl.Text=tostring(math.floor(p*100))
		if onChanged then onChanged(p) end
	end)
	UserInputService.InputChanged:Connect(function(i)
		if dragging and i.UserInputType==Enum.UserInputType.MouseMovement then
			local p=math.clamp((i.Position.X-track.AbsolutePosition.X)/track.AbsoluteSize.X,0,1)
			fill.Size=UDim2.new(p,0,1,0); knob.Position=UDim2.new(p,-7,0.5,-7)
			vl.Text=tostring(math.floor(p*100))
			if onChanged then onChanged(p) end
		end
	end)
	UserInputService.InputEnded:Connect(function(i)
		if i.UserInputType==Enum.UserInputType.MouseButton1 then dragging=false end
	end)
end

