local activeTab = nil

local function createTab(name, icon)
	local tabBtn = New("Frame",{
		Size=UDim2.new(1,0,0,36),BackgroundColor3=T.Surface2,
		BackgroundTransparency=1,BorderSizePixel=0,ZIndex=3,Parent=tabScroll
	})
	New("UICorner",{CornerRadius=UDim.new(0,10),Parent=tabBtn})

	local ind = New("Frame",{
		Size=UDim2.new(0,3,0,20),Position=UDim2.new(0,0,0.5,-10),
		BackgroundColor3=T.Accent,BackgroundTransparency=1,BorderSizePixel=0,ZIndex=4,Parent=tabBtn
	})
	New("UICorner",{CornerRadius=UDim.new(0,2),Parent=ind})

	if icon then
		New("TextLabel",{
			Size=UDim2.new(0,20,1,0),Position=UDim2.new(0,10,0,0),
			BackgroundTransparency=1,Text=icon,TextColor3=T.Muted,TextSize=13,
			Font=Enum.Font.GothamBold,ZIndex=4,Parent=tabBtn
		})
	end

	local lbl = New("TextLabel",{
		Size=UDim2.new(1,-36,1,0),Position=UDim2.new(0,icon and 30 or 12,0,0),
		BackgroundTransparency=1,Text=name,TextColor3=T.Muted,
		TextSize=12,Font=Enum.Font.GothamSemibold,
		TextXAlignment=Enum.TextXAlignment.Left,ZIndex=4,Parent=tabBtn
	})

	-- BUGFIX: ScrollingFrame dengan padding bawah supaya item terakhir tidak terpotong
	local scroll = New("ScrollingFrame",{
		Size=UDim2.new(1,-14,1,-14),Position=UDim2.new(0,10,0,10),
		BackgroundTransparency=1,BorderSizePixel=0,
		ScrollBarThickness=3,ScrollBarImageColor3=T.Border,
		CanvasSize=UDim2.new(0,0,0,0),
		AutomaticCanvasSize=Enum.AutomaticSize.Y,
		Visible=false,ZIndex=3,Parent=content
	})
	New("UIListLayout",{Padding=UDim.new(0,6),Parent=scroll})
	New("UIPadding",{PaddingBottom=UDim.new(0,12),Parent=scroll})

	local tab = {btn=tabBtn,lbl=lbl,ind=ind,scroll=scroll}

	local cb = New("TextButton",{
		Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text="",ZIndex=5,Parent=tabBtn
	})
	cb.MouseButton1Click:Connect(function()
		if activeTab then
			Tween(activeTab.btn,{BackgroundTransparency=1},0.15)
			Tween(activeTab.lbl,{TextColor3=T.Muted},0.15)
			Tween(activeTab.ind,{BackgroundTransparency=1},0.15)
			activeTab.scroll.Visible=false
		end
		Tween(tabBtn,{BackgroundTransparency=0.55},0.15)
		Tween(lbl,{TextColor3=T.Accent},0.15)
		Tween(ind,{BackgroundTransparency=0},0.15)
		scroll.Visible=true; activeTab=tab
	end)
	cb.MouseEnter:Connect(function()
		if activeTab~=tab then Tween(tabBtn,{BackgroundTransparency=0.82},0.12) end
	end)
	cb.MouseLeave:Connect(function()
		if activeTab~=tab then Tween(tabBtn,{BackgroundTransparency=1},0.12) end
	end)
	return tab
end

local function activateFirst(tab)
	tab.btn.BackgroundTransparency=0.55
	tab.lbl.TextColor3=T.Accent
	tab.ind.BackgroundTransparency=0
	tab.scroll.Visible=true
	activeTab=tab
end

