	New("UIStroke",{Color=T.BorderHi,Thickness=1,Transparency=0.4,Parent=listF})
	New("UIListLayout",{Padding=UDim.new(0,2),Parent=listF})
	New("UIPadding",{PaddingTop=UDim.new(0,5),PaddingBottom=UDim.new(0,5),Parent=listF})

	for _,opt in ipairs(options or {}) do
		local ob = New("TextButton",{Size=UDim2.new(1,-8,0,28),Position=UDim2.new(0,4,0,0),
			BackgroundColor3=T.Surface2,BackgroundTransparency=1,BorderSizePixel=0,
