		BackgroundTransparency=1,Text="▾",TextColor3=T.Muted,TextSize=11,
		Font=Enum.Font.Gotham,ZIndex=5,Parent=display})

	-- List pakai parent=gui dengan ZIndex tinggi (BUGFIX utama)
	local listF = New("Frame",{
		Size=UDim2.new(0,145,0,0),Position=UDim2.new(0,0,0,0),
		BackgroundColor3=T.Surface,BorderSizePixel=0,
		ClipsDescendants=true,ZIndex=200,Visible=false,Parent=gui
	})
