local ExpiryDate = {year = 2026, month = 3, day = 23} 

-- // FUNGSI CEK EXPIRED
local function IsExpired()
    local now = os.date("!*t")
    local nowSeconds = os.time({year=now.year, month=now.month, day=now.day, hour=now.hour})
    local expirySeconds = os.time({year=ExpiryDate.year, month=ExpiryDate.month, day=ExpiryDate.day, hour=23, min=59})
    return nowSeconds > expirySeconds
end

if IsExpired() then
    print("SCRIPT EXPIRED! Hubungi Owner.")
    return 
end

