-- // LOOP AUTO COLLECT MONEY
task.spawn(function()
    while true do
        if AutoCollectEnabled and hrp then
            DetectedPlot = GetMyPlot()
            if DetectedPlot then
                local slots = DetectedPlot:FindFirstChild("Slots")
                if slots then
                    local oldPos = hrp.CFrame
                    for _, slot in pairs(slots:GetChildren()) do
                        if not AutoCollectEnabled then break end
                        local collect = slot:FindFirstChild("Collect")
                        if collect then
                            hrp.CFrame = CFrame.new(collect.Position + Vector3.new(0, 3, 0))
                            task.wait(0.3)
                            local prompt = collect:FindFirstChildOfClass("ProximityPrompt") or collect:FindFirstChild("ProximityPrompt", true)
                            if prompt then
                                fireproximityprompt(prompt)
                                task.wait(0.2)
                            end
                        end
                    end
                    hrp.CFrame = oldPos
                end
            end
            task.wait(10) -- Jeda antar putaran sesuai request
        end
        task.wait(0.1)
    end
end)

-- // LOOP AUTO REBIRTH
task.spawn(function()
    while true do
        if AutoRebirthEnabled then
            pcall(function()
                local info = remotes:WaitForChild("GetRebirthInfo"):InvokeServer()
                if info then
                    if info.CurrentPower < info.RequiredPower then
                        remotes:WaitForChild("BuyPower"):FireServer(10)
                    end
                    if info.CanRebirth then
                        remotes:WaitForChild("DoRebirth"):FireServer()
                        task.wait(2)
                        char = Player.Character or Player.CharacterAdded:Wait()
                        hrp = char:WaitForChild("HumanoidRootPart")
                    elseif info.RequiredBrainrots then
                        for _, req in pairs(info.RequiredBrainrots) do
                            if not req.Has and AutoRebirthEnabled then
                                collectSpecific(req.Name)
                            end
                        end
                    end
                end
            end)
        end
        task.wait(0.5)
    end
end)

-- // LOOP AUTO FARM / DUPE
task.spawn(function()
    while true do
        if AutoFarmEnabled and DetectedPlot then
            local slots = DetectedPlot:FindFirstChild("Slots")
            if slots then
                for _, slot in pairs(slots:GetChildren()) do
                    if not AutoFarmEnabled then break end
                    local prompts = slot:FindFirstChild("PromptPart") and slot.PromptPart:FindFirstChild("Promts")
                    if prompts then
                        local place = prompts:FindFirstChild("Place")
                        if place then fireproximityprompt(place) end
                        task.wait(0.1)
                        local pickup = prompts:FindFirstChild("PickUp")
                        if pickup then fireproximityprompt(pickup) end
                    end
                end
            end
        elseif AutoFarmEnabled and not DetectedPlot then
            DetectedPlot = GetMyPlot()
        end
        task.wait(0.5)
    end
end)

