   Flag = "BrainrotToggle",
   Callback = function(Value)
      running = Value
      
      if running then
          task.spawn(function()
              DetectBase()
              
              -- Putaran 1
              TP()
              task.wait(0.4)
              EquipBar2()
              task.wait(0.2)
              Reset()
              task.wait(0.15)
              SpawnPrompt() -- PLACE
