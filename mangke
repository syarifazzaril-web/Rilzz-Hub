              task.wait(0.5)

              -- Loop Utama
              while running do
                  if not running then break end
                  TP()
                  task.wait(0.4)
                  SpawnPrompt() -- PICKUP
                  task.wait(0.4)
                  EquipBar2()
                  task.wait(0.2)
                  Reset()
                  task.wait(0.15)
                  SpawnPrompt() -- PLACE
                  player.CharacterAdded:Wait()
                  task.wait(0.5)
              end
          end)
      end
   end,
})

