-- Auto Brainrot Loop
task.spawn(function()
    while true do
        task.wait(0.3)
        if _G.AutoSecret or _G.AutoMythical or _G.AutoLegendary then
            local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
            if not root then continue end

            for _, v in ipairs(workspace:GetDescendants()) do
                if v:IsA("ProximityPrompt") and not collectedCache[v] then
                    local item = v.Parent and v.Parent.Parent
                    if item and item.Name == "SpawnedItem" then
                        -- Cek Rarity di Label
                        local rarityFound = ""
                        for _, lbl in ipairs(item:GetDescendants()) do
                            if lbl:IsA("TextLabel") then
                                if lbl.Text == "Secret" or lbl.Text == "Mythical" or lbl.Text == "Legendary" then
                                    rarityFound = lbl.Text
                                    break
                                end
                            end
                        end

                        -- Logic Filter
                        local shouldCollect = false
                        if rarityFound == "Secret" and _G.AutoSecret then shouldCollect = true
                        elseif rarityFound == "Mythical" and _G.AutoMythical then shouldCollect = true
                        elseif rarityFound == "Legendary" and _G.AutoLegendary then shouldCollect = true end

                        if shouldCollect then
                            collectedCache[v] = true
                            root.CFrame = CFrame.new(v.Parent.Position + Vector3.new(0, 3, 0))
                            task.wait(0.4)
                            fireproximityprompt(v)
                            task.wait(0.3)
                            TP(SPAWN_POS)
                            task.delay(5, function() collectedCache[v] = nil end)
                            break
                        end
                    end
                end
            end
        end
    end
end)

