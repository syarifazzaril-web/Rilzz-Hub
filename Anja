-- =========================

local function generateRebirthRequirements(maxLevel,startValue,step)

    local tbl = {}

    for i=1,maxLevel do
        tbl[i] = startValue + (i-1)*step
    end

    return tbl

end

local RebirthRequirements = generateRebirthRequirements(200,20,5)

local function getRebirthLevel()

    local stats = player:FindFirstChild("leaderstats")

    if stats and stats:FindFirstChild("Rebirth") then
        return stats.Rebirth.Value
    end

    return 0

end

local function getSpeed()

    local character = player.Character

    if character and character:FindFirstChild("Humanoid") then
        return character.Humanoid.WalkSpeed
    end

    return 0

end

task.spawn(function()

while task.wait(1) do

if _G.AutoRebirth then

local current = getRebirthLevel()

local required = RebirthRequirements[current+1]

if required then

local speed = getSpeed()

if speed >= required then
RebirthRemote:FireServer()
end

end

end

end

end)

-- =========================
-- AUTO BRAINROT
-- =========================

local function getRootPart()

    local char = player.Character

    if char then
        return char:FindFirstChild("HumanoidRootPart")
    end

end

local function goToSpawn()

    local root = getRootPart()

    if root then
        root.CFrame = CFrame.new(SPAWN_POS + Vector3.new(0,3,0))
    end

end

local function getRarity(spawnedItem)

    local infoGUI = spawnedItem:FindFirstChild("InfoGUI",true)
    if not infoGUI then return nil end

    local textLabels = infoGUI:FindFirstChild("TextLabels")
    if not textLabels then return nil end

    local rarityLabel = textLabels:FindFirstChild("Rarity")
    if not rarityLabel then return nil end

    return rarityLabel.Text

end

local function isValidItem(prompt)

    local p2 = prompt.Parent and prompt.Parent.Parent

    if not p2 or p2.Name ~= "SpawnedItem" then
        return false
    end

    local pos = prompt.Parent.Position

    if pos.Y < MIN_Y or pos.Y > MAX_Y then
        return false
    end

    local rarity = getRarity(p2)

    if not rarity then return false end

    if rarity == "Mythical" and COLLECT_MYTHICAL then return true end
    if rarity == "Secret" and COLLECT_SECRET then return true end
    if rarity == "Legendary" and COLLECT_LEGENDARY then return true end

    return false

end

task.spawn(function()

while task.wait(0.3) do

if _G.AutoBrainrot then

local root = getRootPart()

if not root then
task.wait(1)
goToSpawn()
continue
end

local prompt = nil

for _,v in ipairs(workspace:GetDescendants()) do

if v:IsA("ProximityPrompt") and isValidItem(v) and not collected[v] then
prompt = v
break
end

end

if prompt and prompt.Parent then

collected[prompt] = true

local pos = prompt.Parent.Position

root.CFrame = CFrame.new(pos + Vector3.new(0,3,0))

task.wait(0.4)

fireproximityprompt(prompt)

task.wait(0.4)

goToSpawn()

task.delay(2,function()
collected[prompt] = nil
end)

end

end

end

end)

